{
  "name": "actions-msvc-dev-cmd",
  "version": "1.13.0-dev",
  "private": true,
  "description": "GitHub Action to setup Developer Command Prompt for Microsoft Visual C++",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iShark5060/actions-msvc-dev-cmd.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "validate": "node run-quality-checks.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "esbuild src/index.js --bundle --platform=node --format=cjs --target=node24 --outfile=dist/index.cjs --minify",
    "build-debug": "esbuild src/index.js --bundle --platform=node --format=cjs --target=node24 --outfile=dist/index.cjs --sourcemap --keep-names",
    "deps": "pnpm dlx npm-check-updates --target newest -u --reject @types/node && pnpm dlx npm-check-updates @types/node --target semver -u",
    "deps:update": "pnpm update -r --latest && pnpm update @types/node"
  },
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.15.1"
}
