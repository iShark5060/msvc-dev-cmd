{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",

  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "insertFinalNewline": true,

  "sortPackageJson": true,
  "sortImports": {
    "groups": [
      "side_effect",
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ],
    "order": "asc",
    "ignoreCase": true,
    "partitionByNewline": false,
    "newlinesBetween": true,
    "internalPattern": ["~/**", "@/**", "src/**"]
  },

  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "lib/**",
    "coverage/**",
    "pnpm-lock.yaml",
    "tests/fixtures/**",
    "tests/data/**"
  ],

  "overrides": [
    {
      "files": ["**/*.test.*", "**/*.spec.*", "**/__tests__/**", "**/tests/**", "**/test/**"],
      "options": { "printWidth": 120 }
    },
    {
      "files": ["**/*.md", "**/*.mdx"],
      "options": { "proseWrap": "preserve" }
    }
  ]
}
